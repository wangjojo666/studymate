{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Ollama qwen3-vl",
      "type": "shell",
      "command": "ollama run qwen3-vl:30b",
      "problemMatcher": [],
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "Start Backend",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8000",
      "options": {
        "cwd": "${workspaceFolder}\\backend"
      },
      "problemMatcher": [],
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "Start Frontend",
      "type": "shell",
      "command": "node node_modules\\vite\\bin\\vite.js --host 127.0.0.1 --port 5173",
      "options": {
        "cwd": "${workspaceFolder}\\frontend"
      },
      "problemMatcher": [],
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "Start StudyMate",
      "dependsOn": ["Start Backend", "Start Frontend"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
