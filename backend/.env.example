APP_NAME=StudyMate
API_PREFIX=/api
DATABASE_URL=sqlite:///./studymate.db

# Text generation for RAG Q&A, review outlines, and practice questions.
# Supported: ollama, mock, openai, deepseek, qwen, zhipu, custom/openai_compatible
TEXT_LLM_PROVIDER=deepseek
TEXT_LLM_MODEL=deepseek-v4-flash
TEXT_LLM_BASE_URL=https://api.deepseek.com
TEXT_LLM_API_KEY=

# Optional local fallback if the text API is unavailable.
TEXT_LLM_FALLBACK_PROVIDER=ollama
TEXT_LLM_FALLBACK_MODEL=qwen3-vl:30b
TEXT_LLM_FALLBACK_BASE_URL=http://127.0.0.1:11434

# OCR for scanned PDFs through the local vision model.
OCR_LLM_PROVIDER=ollama
OCR_LLM_MODEL=qwen3-vl:30b
OCR_LLM_BASE_URL=http://127.0.0.1:11434

OCR_DEFAULT_MAX_PAGES=10
OCR_MAX_PAGES_PER_REQUEST=50

# Provider-specific keys are also supported:
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# DASHSCOPE_API_KEY=
# ZHIPU_API_KEY=
