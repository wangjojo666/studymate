APP_NAME=StudyMate
APP_ENV=development
API_PREFIX=/api
DATABASE_URL=sqlite:///./studymate.db

# 本地演示默认使用 mock/offline 模式，不需要真实大模型 key。
# 可选值：mock、ollama、openai、deepseek、qwen、zhipu、openai_compatible。
TEXT_LLM_PROVIDER=mock
TEXT_LLM_MODEL=
TEXT_LLM_BASE_URL=
TEXT_LLM_API_KEY=

# 文本模型不可用时的兜底；本地演示保持 none 即可。
TEXT_LLM_FALLBACK_PROVIDER=none
TEXT_LLM_FALLBACK_MODEL=
TEXT_LLM_FALLBACK_BASE_URL=
TEXT_LLM_FALLBACK_API_KEY=

# 图片课件识别/OCR。mock 可保证无模型 key 也能跑通图片演示；
# 扫描版 PDF 的真实 OCR 需要改为 ollama 并启动视觉模型。
OCR_LLM_PROVIDER=mock
OCR_LLM_MODEL=qwen3-vl:30b
OCR_LLM_BASE_URL=http://127.0.0.1:11434
OCR_DEFAULT_MAX_PAGES=10
OCR_MAX_PAGES_PER_REQUEST=20

# 检索配置。默认 hash embedding 轻量稳定；可切换 sentence_transformers 或 openai_compatible。
CHROMA_DIR=storage/chroma
EMBEDDING_PROVIDER=hash
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=16
RAG_TOP_K=5
RAG_MIN_SCORE=0.12
RAG_CONTEXT_MAX_CHARS=6000
RAG_ENABLE_STRICT_SOURCE_MODE=true

# C++ 本地编译运行默认关闭。课程设计演示建议保持 false，只做规则分析。
# 若设置为 true，会在本机临时目录调用 g++，仅有超时限制，不是完整安全沙箱。
CPP_RUN_ENABLED=false
CPP_COMPILE_TIMEOUT_SECONDS=8
CPP_RUN_TIMEOUT_SECONDS=5

# 上传限制。PDF/PPTX/DOCX 使用 DOCUMENT_UPLOAD_MAX_BYTES，TXT 使用 TXT_UPLOAD_MAX_BYTES。
DOCUMENT_UPLOAD_MAX_BYTES=104857600
TXT_UPLOAD_MAX_BYTES=10485760

# 本地演示账号和认证配置。
# 注意：生产环境必须修改 AUTH_SECRET_KEY，不能使用默认开发密钥。
AUTH_SECRET_KEY=studymate-dev-secret-change-me
AUTH_TOKEN_EXPIRE_MINUTES=10080
DEMO_USER_EMAIL=demo@studymate.local
DEMO_USER_PASSWORD=studymate-demo

# Provider-specific keys, only needed when enabling real model providers.
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
