APP_NAME=StudyMate
API_PREFIX=/api
DATABASE_URL=sqlite:///./studymate.db

# Text generation for RAG Q&A, review outlines, and practice questions.
# Supported: ollama, mock, openai, deepseek, qwen, zhipu, custom/openai_compatible
TEXT_LLM_PROVIDER=mock
TEXT_LLM_MODEL=
TEXT_LLM_BASE_URL=
TEXT_LLM_API_KEY=

# Optional fallback if the text API is unavailable. Use "none" to disable fallback.
TEXT_LLM_FALLBACK_PROVIDER=none
TEXT_LLM_FALLBACK_MODEL=
TEXT_LLM_FALLBACK_BASE_URL=
TEXT_LLM_FALLBACK_API_KEY=

# OCR for scanned PDFs through the local vision model.
OCR_LLM_PROVIDER=ollama
OCR_LLM_MODEL=qwen3-vl:30b
OCR_LLM_BASE_URL=http://127.0.0.1:11434

OCR_DEFAULT_MAX_PAGES=10
OCR_MAX_PAGES_PER_REQUEST=20

# Upload limits. PDF/PPTX/DOCX use DOCUMENT_UPLOAD_MAX_BYTES; TXT uses TXT_UPLOAD_MAX_BYTES.
DOCUMENT_UPLOAD_MAX_BYTES=104857600
TXT_UPLOAD_MAX_BYTES=10485760

# Provider-specific keys are also supported:
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# DASHSCOPE_API_KEY=
# ZHIPU_API_KEY=
