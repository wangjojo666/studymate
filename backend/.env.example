APP_NAME=StudyMate
API_PREFIX=/api
DATABASE_URL=sqlite:///./studymate.db

# Use the local Qwen model downloaded in Ollama.
# Supported: ollama, mock, openai, deepseek, qwen, zhipu, custom/openai_compatible
LLM_PROVIDER=ollama
LLM_MODEL=qwen3-vl:30b
LLM_BASE_URL=http://127.0.0.1:11434
LLM_API_KEY=

# OCR for scanned PDFs through the local vision model.
OCR_DEFAULT_MAX_PAGES=10
OCR_MAX_PAGES_PER_REQUEST=50

# Provider-specific keys are also supported:
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# DASHSCOPE_API_KEY=
# ZHIPU_API_KEY=
